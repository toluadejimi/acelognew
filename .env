# =============================================================================
# Frontend (Vite) — LOCAL DEVELOPMENT: npm run dev
# =============================================================================
# Keep VITE_API_URL empty so the dev server proxies /api → DEV_API_PROXY.
# For production builds, see .env.production (used automatically by npm run build).

# Empty = same-origin /api on :8080, then Vite proxies to Laravel (below).
VITE_API_URL=

# Empty unless the SPA URL contains a subpath, e.g. /backend/public/
VITE_PUBLIC_PATH=

# SprintPay (optional — pay link flow)
VITE_SPRINTPAY_API_KEY=499744636474

# --- Vite dev proxy only (not included in npm run build) ---
DEV_API_PROXY=https://host.hotelbiza.online
DEV_API_PATH_PREFIX=/backend/public

# Use local Laravel instead of remote (comment the two lines above and use these):
# DEV_API_PROXY=http://127.0.0.1:8000
# DEV_API_PATH_PREFIX=
