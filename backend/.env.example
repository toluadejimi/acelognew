APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Match the public URL (include /backend/public if the site is in a cPanel subfolder).
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
# Required when the SPA is on another domain than this API (VITE_API_URL points here).
# Comma-separated, no spaces. Example: shop on acelogstores, API on host.hotelbiza:
# CORS_ALLOWED_ORIGINS=https://acelogstores.online,https://www.acelogstores.online,https://host.hotelbiza.online,http://127.0.0.1:8080,http://localhost:8080
CORS_ALLOWED_ORIGINS=https://acelogstores.online,https://www.acelogstores.online,https://host.hotelbiza.online,http://127.0.0.1:8080,http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=acelog
DB_USERNAME=root
DB_PASSWORD=

# SprintPay (for virtual accounts and webhook)
# SPRINTPAY_API_KEY=
# SPRINTPAY_SECRET=
# Required for POST /api/webhooks/sprintpay — must match X-Auth-Token or X-Webhook-Secret or Bearer token
# SPRINTPAY_WEBHOOK_SECRET=

# VTU / bills (SprintPay partner API → VTpass). See docs/VTU_SPRINTPAY.md
# SPRINTPAY_API_BASE=https://web.sprintpay.online/api
# SPRINTPAY_API_TOKEN=
# SPRINTPAY_VTU_ENABLED=false
# SPRINTPAY_VTU_MOCK=false
# Optional path overrides if Readme differs:
# SPRINTPAY_VTU_PATH_AIRTIME=bill/airtime
# SPRINTPAY_VTU_PATH_DATA=bill/data
# SPRINTPAY_VTU_PATH_CABLE_VALIDATE=bill/cable/validate
# SPRINTPAY_VTU_PATH_CABLE_BUY=bill/cable/pay
# SPRINTPAY_VTU_PATH_ELECTRICITY_VALIDATE=bill/electricity/validate
# SPRINTPAY_VTU_PATH_ELECTRICITY_BUY=bill/electricity/pay

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
