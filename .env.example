# ── API base URL (no trailing slash) ─────────────────────────────────────────
# Leave EMPTY so the app uses same-origin /api/... (recommended: hide backend host in Network).
# Then proxy /api on your web server (production) or use DEV_API_PROXY below (dev).
#
# Production (build): usually leave empty and serve the SPA from the same domain that proxies /api → Laravel.
#   VITE_API_URL=
#
# Development: empty + DEV_API_PROXY = where Vite should forward /api (see vite.config.ts).
#   VITE_API_URL=
#   DEV_API_PROXY=https://backend.predoz.com
#   or local Laravel:
#   DEV_API_PROXY=http://127.0.0.1:8000
#
# Legacy / direct backend URL (Network will show this host):
# VITE_API_URL=https://backend.predoz.com

VITE_API_URL=

# Dev only: target for Vite proxy when VITE_API_URL is empty (not sent to browser).
DEV_API_PROXY=http://127.0.0.1:8000

# Optional: for SprintPay redirect flow (pay link)
# VITE_SPRINTPAY_API_KEY=

# Note: Copy this file to .env and update with your actual values.
