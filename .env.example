# ── API base URL (no trailing slash) ─────────────────────────────────────────
# Leave EMPTY so the app uses same-origin /api/... (recommended: hide backend host in Network).
# Then proxy /api on your web server (production) or use DEV_API_PROXY below (dev).
#
# Production (build): usually leave empty and serve the SPA from the same domain that proxies /api → Laravel.
#   VITE_API_URL=
#
# Development: empty + DEV_API_PROXY = where Vite should forward /api (see vite.config.ts).
#   VITE_API_URL=
#   DEV_API_PROXY=https://backend.predoz.com
#   or local Laravel:
#   DEV_API_PROXY=http://127.0.0.1:8000
#
# Legacy / direct backend URL (Network will show this host):
# VITE_API_URL=https://backend.predoz.com

VITE_API_URL=

# Subfolder deploy on cPanel (same value as Browser basename + Vite base). Example:
#   Site: https://host.hotelbiza.online/backend/public/
#   VITE_PUBLIC_PATH=/backend/public
# Leave empty when the domain document root IS Laravel public/ (no /backend/public in URL).
#
# CRITICAL: If this does not match your live URL, login will work in dev but production
# will redirect to /auth forever (wrong /api/... path). Examples:
#   https://acelogstores.online/auth  →  VITE_PUBLIC_PATH=
#   https://domain.com/backend/public/  →  VITE_PUBLIC_PATH=/backend/public
VITE_PUBLIC_PATH=

# Dev only: Vite proxies /api → this host (not sent to browser).
# Local Laravel: http://127.0.0.1:8000 (run: cd backend && php artisan serve)
DEV_API_PROXY=http://127.0.0.1:8000

# If DEV_API_PROXY is your live site and Laravel is under /backend/public, set this or /api/* will 404.
# Example: DEV_API_PROXY=https://host.hotelbiza.online  +  DEV_API_PATH_PREFIX=/backend/public
DEV_API_PATH_PREFIX=

# Optional: for SprintPay redirect flow (pay link)
# VITE_SPRINTPAY_API_KEY=

# Production build: copy to .env.production (or merge) — Vite loads it for `npm run build`.
# See README in docs/PRODUCTION_TROUBLESHOOTING.md
#
# Note: Copy this file to .env and update with your actual values.
